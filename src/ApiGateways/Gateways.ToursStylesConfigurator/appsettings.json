{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "ImageManagementRequests": {
        "ClusterId": "daprSidecar",
        "Match": {
          "Path": "images-management/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/images-management" },
          { "PathPrefix": "/api" },
          {
            "RequestHeader": "dapr-app-id",
            "Set": "images-management-api"
          }
        ]
      },
      "InteriorDesigners": {
        "ClusterId": "daprSidecar",
        "Match": {
          "Path": "interior-designers/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/interior-designers" },
          { "PathPrefix": "/api" },
          {
            "RequestHeader": "dapr-app-id",
            "Set": "interior-designers-api"
          }
        ]
      },
      "ToursStylesConfigurator": {
        "ClusterId": "daprSidecar",
        "Match": {
          "Path": "tours-styles-configurator/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/tours-styles-configurator" },
          {
            "RequestHeader": "dapr-app-id",
            "Set": "tours-styles-configurator-api"
          }
        ]
      }      
    },
    "Clusters": {
      "daprSidecar": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:3500/"
          }
        }
      }
    }
  }
}


