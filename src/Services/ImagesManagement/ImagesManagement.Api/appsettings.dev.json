{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Level:u3}][{TraceId}][{SpanId}][{StatusCode}][{Timestamp:HH:mm:ss.fff}][T{ThreadId:D2}][{ApplicationName}][{EnvironmentName}][{MachineName}][T{ThreadId:D2}][{SourceContext}] {Message:l}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
